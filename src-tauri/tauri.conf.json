{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Chinotto",
  "version": "1.0.0",
  "identifier": "app.chinotto",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Chinotto",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "titleBarStyle": "Transparent",
        "backgroundColor": "#0a0a0e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "exceptionDomain": null,
      "infoPlist": "Info.plist",
      "entitlements": "Chinotto.entitlements",
      "dmg": {
        "background": "dmg-background.png"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQwMTFGMjkwN0FBMTgwNTgKUldSWWdLRjZrUElSUUJpaDNuNUh1c1k0UG5QOGtUQjlmZEl6RkpEdFZlaklxOE1TZ2V4Mmc3ZlkK",
      "endpoints": [
        "https://github.com/AleksandrMalinin/chinotto/releases/latest/download/latest.json"
      ]
    }
  }
}
